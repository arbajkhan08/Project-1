R2_PUBLIC_URL="https://pub-xxxxx.r2.dev"

# NextAuth (if using Google login for students)
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AdSense (once approved)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=""
